{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS 11 API exercising every feature of @bymax-one/nest-cache against Redis 7 — read-through caching, namespace/tenant isolation, Pub/Sub, TTL keyspace events, Lua single-flight, and the Cache Admin (Explorer) backend.",
  "keywords": [
    "bymax",
    "bymax-one",
    "nest-cache",
    "nestjs",
    "redis",
    "ioredis",
    "cache",
    "pubsub",
    "api",
    "example"
  ],
  "homepage": "https://github.com/bymaxone/nest-cache-example/tree/main/apps/api#readme",
  "bugs": {
    "url": "https://github.com/bymaxone/nest-cache-example/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bymaxone/nest-cache-example.git",
    "directory": "apps/api"
  },
  "license": "MIT",
  "author": {
    "name": "Bymax One",
    "url": "https://github.com/bymaxone"
  },
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config jest-e2e.config.mjs --runInBand",
    "verify:stampede": "nest build && node scripts/verify-stampede.mjs"
  },
  "dependencies": {
    "@bymax-one/nest-cache": "file:../../../nest-cache",
    "@msgpack/msgpack": "^3.1.3",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/platform-socket.io": "^11",
    "@nestjs/websockets": "^11",
    "ioredis": "^5",
    "reflect-metadata": "^0.2",
    "socket.io": "^4",
    "zod": "^4"
  },
  "devDependencies": {
    "@jest/globals": "^30",
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11.1.27",
    "@testcontainers/redis": "^12.0.3",
    "@types/express": "^5",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "ioredis-mock": "^8.13.1",
    "jest": "^30",
    "ts-jest": "^29"
  }
}
